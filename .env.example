# ◈ Free Antigravity - API and Provider Configurations ◈

# NVIDIA NIM Credentials (Default provider for routing)
NVIDIA_NIM_API_KEY=""
NIM_MODEL="deepseek-ai/deepseek-v4-pro"

# Port mapping for local execution (default is 8084)
PORT=8084
HOST="127.0.0.1"

# 🧠 Model Mapping Configuration (Optional)
# Maps CLI-requested model IDs (e.g., gemini-3.5-flash) to any target provider model
MODEL_MAP_GEMINI_3_5_FLASH="nvidia/google/gemma-4-31b-it"
MODEL_MAP_GEMINI_3_1_PRO_HIGH="nvidia/deepseek-ai/deepseek-v4-pro"
MODEL_MAP_CLAUDE_SONNET_4_6="nvidia/deepseek-ai/deepseek-v4-pro"
MODEL_MAP_CLAUDE_OPUS_4_6_THINKING="nvidia/deepseek-ai/deepseek-v4-pro"

# 🎭 CLI Footer Customization (Optional)
# Customize the email and plan name displayed in the Antigravity CLI footer
MOCK_EMAIL="your-email@gmail.com"
MOCK_PLAN_NAME="Antigravity Starter Quota"
